{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-terminal-ghostty",
  "name": {
    "ko": "터미널(고스티)",
    "en": "Terminal (Ghostty)"
  },
  "version": "0.0.1",
  "description": {
    "ko": "Ghostty VT 엔진 기반 터미널 — 기존 터미널과 나란히 추가되는 두 번째 터미널 프로그램.",
    "en": "Terminal powered by the Ghostty VT engine — a second terminal program alongside the existing one."
  },
  "entry": "main.js",
  "sidecars": [
    {
      "name": "terminal-ghostty",
      "interface": {
        "id": "soksak-spec-sidecar-terminal",
        "range": "0.0.1"
      }
    }
  ],
  "permissions": [
    "ui",
    "commands",
    "programs",
    "process",
    "pty",
    "terminal",
    "terminal:read",
    "data"
  ],
  "implements": [
    {
      "id": "soksak-spec-plugin-terminal",
      "version": "0.0.1"
    }
  ],
  "consumes": [
    {
      "id": "soksak-spec-plugin-sidebar-file-tree",
      "range": "^0.0.1"
    }
  ],
  "contributes": {
    "programs": [
      {
        "id": "terminal-ghostty",
        "title": {
          "ko": "터미널(고스티)",
          "en": "Terminal (Ghostty)"
        },
        "kind": "view",
        "view": "content"
      }
    ],
    "views": [
      {
        "id": "content",
        "title": {
          "ko": "터미널(고스티)",
          "en": "Terminal (Ghostty)"
        },
        "icon": "🬀",
        "placements": [
          "content"
        ],
        "sidebar": {
          "left": [
            {
              "contract": "soksak-spec-plugin-sidebar-file-tree",
              "range": "^0.0.1",
              "view": "tree",
              "instance": "shared"
            }
          ]
        },
        "defaultPlacement": "content",
        "status": [
          "connecting",
          "error"
        ]
      }
    ],
    "commands": [
      {
        "name": "ping",
        "title": {
          "ko": "핑",
          "en": "Ping"
        }
      },
      {
        "name": "send",
        "title": {
          "ko": "텍스트 전송",
          "en": "Send Text"
        }
      },
      {
        "name": "clear",
        "title": {
          "ko": "지우기",
          "en": "Clear"
        }
      },
      {
        "name": "resume",
        "title": {
          "ko": "세션 이어가기",
          "en": "Resume Session"
        }
      },
      {
        "name": "split-pane",
        "title": {
          "ko": "탭 내 분할",
          "en": "Split Pane (Within-Tab)"
        }
      },
      {
        "name": "panes",
        "title": {
          "ko": "탭 내 pane 목록",
          "en": "List Panes (Within-Tab)"
        }
      },
      {
        "name": "close-pane",
        "title": {
          "ko": "탭 내 pane 닫기",
          "en": "Close Pane (Within-Tab)"
        }
      }
    ],
    "nodes": [
      {
        "id": "terminal",
        "description": {
          "ko": "Ghostty 터미널 컨테이너",
          "en": "Ghostty terminal container"
        }
      }
    ]
  },
  "configuration": [
    {
      "key": "splitMode",
      "type": "enum",
      "default": "tab",
      "title": {
        "ko": "분할 방식",
        "en": "Split mode"
      },
      "description": {
        "ko": "터미널 분할을 탭(별도 패널)으로 할지 탭 내부(뷰 안 pane)로 할지.",
        "en": "Whether a terminal split makes a new tab (panel) or an internal pane within the view."
      },
      "enum": [
        "tab",
        "within-tab"
      ],
      "enumLabels": [
        {
          "ko": "탭 분할",
          "en": "Tab split"
        },
        {
          "ko": "탭 내 분할",
          "en": "Within-tab split"
        }
      ]
    }
  ]
}
